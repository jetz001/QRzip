# ============================================================
# QRZIP — AI Provider Keys (Example / Template)
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่า key จริง
# ============================================================

# ── Groq ─────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Mistral ───────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_MODEL=mistral-large-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1

MISTRAL_SMALL_API_KEY=your_mistral_small_api_key
MISTRAL_SMALL_MODEL=mistral-small-latest

# ── Cerebras ──────────────────────────────────────────────
CEREBRAS_API_KEY=your_cerebras_api_key
CEREBRAS_MODEL=gemma-4-31b
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# ── Fireworks ─────────────────────────────────────────────
FIREWORKS_API_KEY=your_fireworks_api_key
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-pro
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# ── DeepSeek (optional) ───────────────────────────────────
# DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── Default provider ──────────────────────────────────────
AI_PROVIDER=groq
